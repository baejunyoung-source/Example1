<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FFFFFF"
    android:paddingHorizontal="16dp" android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBack2"
            android:layout_width="36dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="뒤로가기"
            android:padding="2dp"
            android:src="@drawable/icon"
            tools:ignore="TouchTargetSizeCheck" />

        <TextView
            android:id="@+id/nickName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="닉네임님의 온도"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="닉네임님의 현재 온도입니다"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="89dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_blue_outline_rounded"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/currentTemperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="36.5도"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="온도를 입력해 주세요"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="89dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_blue_outline_rounded"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/targetTemperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="36.5도"
            android:textSize="24sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="사유를 입력해주세요"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editTextText7"
        android:layout_width="match_parent" android:layout_height="140dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_blue_outline_rounded"
        android:gravity="top"
        android:hint="이렇게 평가한 이유를 적어주세요"
        android:inputType="textMultiLine"
        android:padding="12dp"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <android.widget.Button
        android:id="@+id/button10"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_blue_button"
        android:text="입력완료"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>