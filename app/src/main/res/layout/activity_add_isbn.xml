<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@android:color/transparent"
                android:contentDescription="뒤로가기"
                android:padding="2dp"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="상품 판매하기"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="단과대 / 학과 선택"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinnerCollege"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_blue_outline_rounded" />

            <Spinner
                android:id="@+id/spinnerMajor"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_blue_outline_rounded" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="ISBN 혹은 책 이름을 입력해주세요"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp">

            <EditText
                android:id="@+id/editBookSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_blue_outline_rounded"
                android:singleLine="true"
                android:text="[국내도서] 스프링 부트 4 개발자 되기 + AI: 자바 편"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="50dp" />

            <ImageButton
                android:id="@+id/btnBookSearch"
                android:layout_width="42dp"
                android:layout_height="match_parent"
                android:layout_gravity="end|center_vertical"
                android:background="@android:color/transparent"
                android:contentDescription="책 검색"
                android:padding="9dp"
                android:src="@drawable/ic_search" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/layoutBookResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgBookCover"
                android:layout_width="90dp"
                android:layout_height="110dp"
                android:contentDescription="도서 표지"
                android:scaleType="fitCenter"
                android:src="@drawable/img_1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtBookTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:text="[국내도서] 스프링 부트 4 개발자 되기 + AI: 자바 편"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtBookAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="신선영 저자(글)"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtBookPublisher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="골든래빗(주)"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="필기량이 얼마나 되나요?"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/groupWriting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/btnWritingNone"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="4dp"
                android:button="@null"
                android:background="@drawable/bg_radio_selector"
                android:gravity="center"
                android:text="없음"
                android:textColor="@color/color_radio_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/btnWritingLittle"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:button="@null"
                android:background="@drawable/bg_radio_selector"
                android:gravity="center"
                android:text="조금 있음"
                android:textColor="@color/color_radio_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/btnWritingNormal"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:button="@null"
                android:background="@drawable/bg_radio_selector"
                android:gravity="center"
                android:text="적당함"
                android:textColor="@color/color_radio_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/btnWritingMany"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:button="@null"
                android:background="@drawable/bg_radio_selector"
                android:gravity="center"
                android:text="많음"
                android:textColor="@color/color_radio_text"
                android:textSize="15sp"
                android:textStyle="bold" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="보존 상태는 어떤가요? (복수선택 가능)"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/groupCondition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/btnConditionClean"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="4dp"
                android:button="@null"
                android:background="@drawable/bg_radio_selector"
                android:gravity="center"
                android:text="새것과 같음"
                android:textColor="@color/color_radio_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/btnConditionNoMark"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:button="@null"
                android:background="@drawable/bg_radio_selector"
                android:gravity="center"
                android:text="변색 없음"
                android:textColor="@color/color_radio_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/btnConditionNoDamage"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:button="@null"
                android:background="@drawable/bg_radio_selector"
                android:gravity="center"
                android:text="훼손 없음"
                android:textColor="@color/color_radio_text"
                android:textSize="15sp"
                android:textStyle="bold" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="희망하는 판매 가격을 입력해주세요"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editPrice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_blue_outline_rounded"
            android:inputType="number"
            android:textColor="#000000"
            android:textSize="16sp"
            android:paddingHorizontal="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="상품 설명을 입력해주세요"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editDescription"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_blue_outline_rounded"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:textColor="#000000"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="160dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_blue_button"
            android:text="입력 완료"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>